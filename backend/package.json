{
  "name": "aleyart-examai-pro-backend",
  "version": "2.0.0",
  "description": "ALEYART ACADEMY ExamAI Pro — Backend API",
  "main": "src/server.js",
  "scripts": {
    "start":          "node src/server.js",
    "dev":            "nodemon src/server.js",
    "build":          "npx prisma generate",
    "postinstall":    "npx prisma generate",
    "db:generate":    "npx prisma generate",
    "db:migrate":     "npx prisma migrate deploy",
    "db:seed":        "node prisma/seed.js",
    "db:push":        "npx prisma db push",
    "db:studio":      "npx prisma studio",
    "setup":          "npm install && npx prisma generate && npx prisma migrate deploy && node prisma/seed.js"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk":  "^0.30.0",
    "@prisma/client":     "^5.22.0",
    "bcryptjs":           "^2.4.3",
    "compression":        "^1.7.4",
    "cors":               "^2.8.5",
    "docx":               "^8.5.0",
    "dotenv":             "^16.4.5",
    "express":            "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet":             "^8.0.0",
    "jsonwebtoken":       "^9.0.2",
    "morgan":             "^1.10.0",
    "multer":             "^1.4.5-lts.1",
    "prisma":             "^5.22.0",
    "uuid":               "^10.0.0",
    "xlsx":               "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
